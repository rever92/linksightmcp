# MCP auth token — protects the MCP endpoint itself
MCP_AUTH_TOKEN=your-secret-mcp-token

# Linksight API base URL (the backend this MCP proxies to)
LINKSIGHT_API_URL=https://yourdomain.com/api

# Linksight user credentials (pre-authenticated, no login tool needed)
LINKSIGHT_EMAIL=your@email.com
LINKSIGHT_PASSWORD=your-password

# Port (Passenger overrides via PORT)
MCP_PORT=3002
